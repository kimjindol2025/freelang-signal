// ============================================================================
// 전체 테스트 실행
// ============================================================================

pub fn run_all_tests() -> Vec<TestResult> {
    let mut results = Vec::new();

    // Group A: ZKP Engine
    results.push(test_a1_pedersen_commitment_creation());
    results.push(test_a2_pedersen_commitment_verification());
    results.push(test_a3_schnorr_proof_generation());
    results.push(test_a4_schnorr_proof_verification());
    results.push(test_a5_forged_proof_rejection());
    results.push(test_a6_batch_proof_generation());

    // Group B: Crypto Engine
    results.push(test_b1_sha3_hash());
    results.push(test_b2_hkdf_key_derivation());
    results.push(test_b3_aes_gcm_encryption());
    results.push(test_b4_aes_gcm_decryption());
    results.push(test_b5_hmac_sha256());
    results.push(test_b6_auth_tag_tampering_detection());

    // Group C: Transport Layer
    results.push(test_c1_channel_handshake());
    results.push(test_c2_message_send_receive());
    results.push(test_c3_channel_throughput());
    results.push(test_c4_zero_copy_bus_push_pop());
    results.push(test_c5_bus_capacity_overflow());
    results.push(test_c6_bus_batch_processing());

    // Group D: Signal Anomaly Detection
    results.push(test_d1_signal_detector_creation());
    results.push(test_d2_signal_analysis());
    results.push(test_d3_jamming_detection());
    results.push(test_d4_ngram_anomaly_detection());
    results.push(test_d5_ensemble_confidence_calculation());
    results.push(test_d6_detector_accuracy());

    // Group E: Replay Guard
    results.push(test_e1_replay_guard_new_nonce());
    results.push(test_e2_replay_detection());
    results.push(test_e3_replay_guard_stats());
    results.push(test_e4_nonce_generator());
    results.push(test_e5_enhanced_replay_guard());
    results.push(test_e6_nonce_batch_generation());

    // Group F: Integration - ZKP + AES + Channel
    results.push(test_f1_integration_basic());
    results.push(test_f2_integration_security());
    results.push(test_f3_integration_channel());
    results.push(test_f4_integration_throughput());
    results.push(test_f5_integration_replay());
    results.push(test_f6_integration_e2e());

    // Group G: Ensemble Confidence
    results.push(test_g1_ensemble_basic());
    results.push(test_g2_ensemble_weights());
    results.push(test_g3_ensemble_confidence());
    results.push(test_g4_ensemble_accuracy());
    results.push(test_g5_ensemble_detection());
    results.push(test_g6_ensemble_e2e());

    // Group H: E2E Integration
    results.push(test_h1_e2e_full_flow());
    results.push(test_h2_e2e_throughput());
    results.push(test_h3_e2e_security());
    results.push(test_h4_e2e_detection());
    results.push(test_h5_e2e_verification());
    results.push(test_h6_e2e_final());

    results
}

pub fn print_test_summary(results: &[TestResult]) {
    let mut passed = 0;
    let mut failed = 0;
    let mut total_time = 0u64;

    println!("\n╔════════════════════════════════════════════════════════╗");
    println!("║          FL-Signal Test Results                        ║");
    println!("╚════════════════════════════════════════════════════════╝\n");

    for result in results {
        println!("{}", result.to_string());

        if result.passed {
            passed += 1;
        } else {
            failed += 1;
        }

        total_time += result.elapsed_us;
    }

    println!("\n────────────────────────────────────────────────────────");
    println!("Summary: {} passed, {} failed", passed, failed);
    println!("Total time: {}µs", total_time);
    println!("════════════════════════════════════════════════════════\n");
}

// ============================================================================
// 시간 측정 유틸리티 (시뮬레이션)
// ============================================================================

fn get_time_us() -> u64 {
    // 시뮬레이션을 위한 가짜 타이머 (실제로는 시스템 타이머 사용)
    // Day 1-2: ZKP 테스트는 < 1ms 범위
    // Day 3-4: Crypto 테스트는 < 100µs 범위
    static mut COUNTER: u64 = 0;
    unsafe {
        COUNTER = COUNTER.wrapping_add(1);
        COUNTER % 1000
    }
}

